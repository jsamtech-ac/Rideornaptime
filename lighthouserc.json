{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/first-visit",
        "http://localhost:3000/characters",
        "http://localhost:3000/rides",
        "http://localhost:3000/itineraries",
        "http://localhost:3000/lightning-lane",
        "http://localhost:3000/food",
        "http://localhost:3000/packing-list",
        "http://localhost:3000/seasonal",
        "http://localhost:3000/saving-money",
        "http://localhost:3000/hidden-gems",
        "http://localhost:3000/fireworks",
        "http://localhost:3000/best-strollers"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": { "target": "filesystem", "outputDir": "qa-report/lhci" }
  }
}
