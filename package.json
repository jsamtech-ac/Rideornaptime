    "qa:build": "next build",
    "qa:links": "linkinator http://localhost:3000 --config linkinator.config.json",
    "qa:a11y": "playwright test",
    "qa:lhci": "lhci autorun"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.12.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "html-validate": "^10.12.2",
    "linkinator": "^7.6.1",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0"
