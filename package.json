{
  "name": "rideornaptime",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "qa": "node scripts/qa/run.mjs",
    "qa:types": "tsc --noEmit",
    "qa:lint": "next lint --max-warnings=0",
    "qa:format": "prettier --check .",
